DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
PORT=3001
HOST=0.0.0.0

HTTPS_ENABLED=true
SSL_KEY_PATH=C:\certs\mxr-server-key.pem
SSL_CERT_PATH=C:\certs\mxr-server-cert.pem
COOKIE_SECURE=true

CLIENT_ORIGIN=https://CLIENT_LAN_IP:3000

SESSION_SECRET=replace-with-a-long-random-session-secret
AUTH_TOKEN_SECRET=replace-with-a-different-long-random-token-secret
SESSION_MAX_AGE_MS=900000

AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# Render production example:
# HTTPS_ENABLED=false
# COOKIE_SECURE=true
# CLIENT_ORIGIN=https://your-vercel-app.vercel.app
# DATABASE_URL=your-render-postgres-internal-url
